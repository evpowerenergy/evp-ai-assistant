# ============================================
# AI Assistant - ค่าสำหรับ deploy ขึ้น Cloud Run (แบบสคริปต์บนเครื่อง)
# ============================================
# 1. copy ไฟล์นี้ไปเป็น .env.cloudrun ที่ root โปรเจกต์
#    cp env.cloudrun.example .env.cloudrun
# 2. แก้ค่าใน .env.cloudrun ให้ตรงกับโปรเจกต์คุณ
# 3. รัน ./scripts/deploy-backend.sh หรือ ./scripts/deploy-frontend.sh
#
# หมายเหตุ: .env.cloudrun ถูก git ignore — อย่า commit

# ----- GCP (override ได้ถ้าต้องการ) -----
# export PROJECT_ID=ev-power-energy-prod
# export REGION=asia-southeast1
# หลัง deploy ด้วย --no-allow-unauthenticated ต้องให้สิทธิ์ invoker ไม่งั้นโดเมน/หน้า login จะ Forbidden
# ค่าเริ่มต้น = เปิดสาธารณะ (allUsers) — ตั้งเป็น 0 ถ้าไม่ต้องการให้สคริปต์ bind อัตโนมัติ
# export CLOUD_RUN_PUBLIC=1

# ----- Backend (ใช้ตอน deploy backend) -----
export SUPABASE_URL=https://your-project.supabase.co
export SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
export OPENAI_API_KEY=sk-your_openai_key
# Optional; ถ้าไม่ใส่ backend ใช้ default ใน config (gpt-5.4)
# export OPENAI_MODEL=gpt-5.4
export LINE_CHANNEL_SECRET=
export LINE_CHANNEL_ACCESS_TOKEN=
# CORS: ใส่ origin ของ frontend ที่จะเรียก API (คั่นด้วย comma ไม่มีช่องว่างสำคัญเกินไป — ใช้ strip ในโค้ดแล้ว)
# ต้องใส่ทั้ง custom domain และ URL ของ Cloud Run ถ้าใช้ทั้งสองแบบ ไม่งั้นโดเมนที่ไม่ได้ใส่จะโดน CORS block
# ตัวอย่าง:
# export CORS_ORIGINS=https://assistant.evpowerenergy.com,https://ai-assistant-frontend-1089649909937.asia-southeast1.run.app
export CORS_ORIGINS=https://ai-assistant-frontend-1089649909937.asia-southeast1.run.app

# ----- Frontend build (ใช้ตอน deploy frontend) -----
export NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
export NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# ชี้ไป URL ของ service ai-assistant-backend บน Cloud Run (หลัง deploy backend แล้ว)
export NEXT_PUBLIC_API_URL=https://ai-assistant-backend-xxxxx-as.a.run.app
