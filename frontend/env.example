# ============================================
# AI Assistant Frontend - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp env.example .env.local
#
# Note: Next.js automatically loads .env.local
# All variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from: Supabase Dashboard > Settings > API
# Use ANON KEY (not service role key) for frontend
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# Backend API Configuration (Required)
# ============================================
# Backend API URL
# Development: http://localhost:8000
# Production: https://your-backend-service-url.run.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Notes
# ============================================
# - Never commit .env.local file to git
# - NEXT_PUBLIC_ variables are exposed to browser (public)
# - Use anon key (not service role key) for frontend
# - For production, set these in Cloud Run environment variables
