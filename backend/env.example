# ============================================
# AI Assistant Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp env.example .env

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# OpenAI Configuration (Required)
# ============================================
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# LINE Messaging API (Optional - Phase 4)
# ============================================
# Get these from: LINE Developers Console
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API Port (default: 8000)
API_PORT=8000

# ============================================
# CORS Configuration
# ============================================
# Allowed origins (comma-separated)
# For development, include localhost
# For production, include every browser origin that calls this API (custom domain + Cloud Run URL if both are used)
# Example: https://assistant.evpowerenergy.com,https://ai-assistant-frontend-xxxxx.asia-southeast1.run.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Notes
# ============================================
# - Never commit .env file to git
# - Keep service role key secure (backend only)
# - Use anon key for frontend (public)
# - For production, use environment variables from Cloud Run
